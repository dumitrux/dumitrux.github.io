---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { social, siteMeta } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  alternateEn?: string;
  alternateEs?: string;
}

const { title, description, image, canonical, alternateEn, alternateEs } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const site = Astro.site?.origin ?? 'https://dumitrux.github.io';
const defaultDescription = 'Dumitru - Data Platform Specialist, Cloud Engineer, DevOps & Data Engineer portfolio';
const metaDescription = description || defaultDescription;
const canonicalURL = canonical || new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image ?? siteMeta.defaultOgImage, site).href;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteMeta.name,
  url: site,
  jobTitle: 'Data Platform Specialist, Cloud Engineer, DevOps & Data Engineer',
  sameAs: [social.github, social.linkedin],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    {alternateEn && <link rel="alternate" hreflang="en" href={alternateEn} />}
    {alternateEs && <link rel="alternate" hreflang="es" href={alternateEs} />}
    {(alternateEn || alternateEs) && <link rel="alternate" hreflang="x-default" href={alternateEn || canonicalURL} />}
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Dumitru" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <title>{title}</title>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <ClientRouter />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      document.addEventListener('astro:before-swap', (e) => {
        const t = localStorage.getItem('theme');
        if (t === 'light') {
          e.newDocument.documentElement.classList.remove('dark');
        } else {
          e.newDocument.documentElement.classList.add('dark');
        }
      });
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-dark-bg text-gray-900 dark:text-dark-text min-h-screen font-sans antialiased transition-colors duration-300">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-white">{t('a11y.skip')}</a>
    <Header />
    <main id="main-content" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />
    <button
      id="go-to-top"
      type="button"
      class="fixed bottom-6 right-6 z-50 hidden p-3 rounded-full bg-primary text-white shadow-lg hover:bg-primary/90 transition-all duration-300 opacity-0"
      aria-label="Go to top"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
    </button>
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('go-to-top');
        if (!btn) return;
        function toggle() {
          if (window.scrollY > 300) {
            btn.classList.remove('hidden');
            requestAnimationFrame(() => btn.classList.add('opacity-100'));
          } else {
            btn.classList.remove('opacity-100');
            btn.classList.add('opacity-0');
            setTimeout(() => { if (window.scrollY <= 300) btn.classList.add('hidden'); }, 300);
          }
        }
        window.addEventListener('scroll', toggle, { passive: true });
        btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        toggle();
      });
    </script>
  </body>
</html>
