---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/ui';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Dumitru - Data Platform Specialist, Cloud Engineer, DevOps & Data Engineer portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      document.addEventListener('astro:before-swap', (e) => {
        const t = localStorage.getItem('theme');
        if (t === 'light') {
          e.newDocument.documentElement.classList.remove('dark');
        } else {
          e.newDocument.documentElement.classList.add('dark');
        }
      });
    </script>
  </head>
  <body class="bg-white dark:bg-dark-bg text-gray-900 dark:text-dark-text min-h-screen font-sans antialiased transition-colors duration-300">
    <Header />
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
