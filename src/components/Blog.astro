---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection('blog'))
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => {
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;
    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 3);
---

<section id="blog" class="py-12 scroll-mt-20">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{t('section.blog')}</h2>
    <a href={lang === 'en' ? '/' : '/es/'} class="px-4 py-2 text-sm font-medium text-primary border border-primary/20 rounded-lg hover:bg-primary/10 transition-colors">
      {lang === 'en' ? 'View All' : 'Ver todos'}
    </a>
  </div>
  {posts.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map((post) => (
        <a
          href={lang === 'en' ? `/blog/${post.data.permalink}/` : `/es/blog/${post.data.permalink}/`}
          class="group bg-gray-200 dark:bg-dark-card border-2 border-gray-300 dark:border-dark-border rounded-xl overflow-hidden hover:border-primary/50 transition-colors block"
        >
          {post.data.thumbnail && (
            <img
              src={post.data.thumbnail}
              alt={post.data.title}
              class="w-full h-40 object-cover"
              loading="lazy"
            />
          )}
          <div class="p-5">
            <p class="text-xs text-gray-500 dark:text-dark-muted mb-2">
              {post.data.pinned && <span class="text-primary font-semibold mr-2">{lang === 'en' ? '📌 Pinned' : '📌 Fijado'}</span>}
              {post.data.date.toLocaleDateString(lang === 'en' ? 'en-GB' : 'es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h3 class="text-gray-900 dark:text-white font-semibold mb-2 group-hover:text-primary transition-colors">{post.data.title}</h3>
            <p class="text-gray-800 dark:text-dark-muted text-sm leading-relaxed line-clamp-2">{post.data.description}</p>
            {post.data.tags && (
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="px-2 py-1 text-xs rounded-md bg-primary/10 text-primary border border-primary/20">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="bg-gray-200 dark:bg-dark-card border-2 border-gray-300 dark:border-dark-border rounded-xl p-8 text-center">
      <p class="text-gray-800 dark:text-dark-muted">{t('blog.coming')}</p>
    </div>
  )}
</section>
