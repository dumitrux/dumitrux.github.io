---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { personalProjects } from '../data/projects';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'es' ? '/es' : '';
---

<section id="projects" class="py-12 scroll-mt-20">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">{t('section.personal')}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {personalProjects.map((project, i) => (
      <a
        href={`${prefix}/project/${project.slug}`}
        class:list={['group bg-gray-100 dark:bg-dark-card border border-gray-300 dark:border-dark-border rounded-xl p-5 hover:border-secondary/50 transition-colors block', i >= 4 && 'hidden project-extra']}
      >
        <div class="flex items-center gap-2 mb-2">
          <h3 class="text-gray-900 dark:text-white font-semibold group-hover:text-secondary transition-colors">{project.name}</h3>
        </div>
        <p class="text-gray-800 dark:text-dark-muted text-sm mb-3 leading-relaxed">{project.description[lang]}</p>
        <div class="flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="px-2 py-1 text-xs rounded-md bg-secondary/10 text-secondary border border-secondary/20">
              {tag}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
  {personalProjects.length > 4 && (
    <div class="mt-6 text-center">
      <button
        id="projects-toggle"
        type="button"
        class="px-4 py-2 text-sm font-medium text-secondary border border-secondary/20 rounded-lg hover:bg-secondary/10 transition-colors"
      >
        {lang === 'en' ? 'View All' : 'Ver todo'}
      </button>
    </div>
  )}
</section>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('projects-toggle')?.addEventListener('click', function() {
      const extras = document.querySelectorAll('.project-extra');
      const expanded = !extras[0]?.classList.contains('hidden');
      extras.forEach(el => el.classList.toggle('hidden', expanded));
      this.textContent = expanded
        ? (document.documentElement.lang === 'es' ? 'Ver todo' : 'View All')
        : (document.documentElement.lang === 'es' ? 'Ver menos' : 'View Less');
    });
  });
</script>
