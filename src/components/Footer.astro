---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { social } from '../data/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-gray-200 dark:border-dark-border mt-6">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-gray-500 dark:text-dark-muted text-sm">&copy; {new Date().getFullYear()} Dumitru. {t('footer.built')}</p>
    <div class="flex items-center gap-4">
      <a href={social.github} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-dark-muted hover:text-gray-900 dark:hover:text-white transition-colors text-sm">GitHub</a>
      <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-dark-muted hover:text-gray-900 dark:hover:text-white transition-colors text-sm">LinkedIn</a>
    </div>
  </div>
</footer>
