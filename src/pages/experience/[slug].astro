---
import Layout from '../../layouts/Layout.astro';
import ExperienceDetail from '../../components/ExperienceDetail.astro';
import { workExperience } from '../../data/experience';

export function getStaticPaths() {
  return workExperience.map((exp) => ({
    params: { slug: exp.slug },
    props: { exp },
  }));
}

const { exp } = Astro.props;
---

<Layout
  title={`${exp.name} | Dumitru`}
  description={exp.details.en}
  alternateEn={`https://dumitrux.github.io/experience/${exp.slug}/`}
  alternateEs={`https://dumitrux.github.io/es/experience/${exp.slug}/`}
>
  <ExperienceDetail exp={exp} lang="en" />
</Layout>
