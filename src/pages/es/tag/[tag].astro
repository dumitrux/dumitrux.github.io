---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import TagPage from '../../../components/TagPage.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const posts = (await getCollection('blog')).filter((post) => post.data.lang === 'es');
  const tags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))];

  return tags.map((tag) => ({
    params: { tag: tag.toLowerCase().replace(/[\s/]+/g, '-') },
    props: { tag },
  }));
}) satisfies GetStaticPaths;

const { tag } = Astro.props;

const allPosts = (await getCollection('blog')).filter((post) => post.data.lang === 'es');
const mainTagOrder = ['DevOps', 'Data', 'AI/ML', 'AI', 'Infrastructure', 'Software', 'Software Engineering', 'Python', 'Computer Science', 'Architecture', 'Compliance', 'Personal', 'Projects'];
const usedTags = new Set(allPosts.flatMap((post) => post.data.tags ?? []));
const allTags = mainTagOrder.filter((name) => usedTags.has(name));

const posts = allPosts
  .filter((post) => post.data.tags?.includes(tag))
  .sort((a, b) => {
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const slug = tag.toLowerCase().replace(/[\s/]+/g, '-');
---

<Layout
  title={`${tag} | Blog | Dumitru`}
  description={`Posts del blog con la etiqueta ${tag}.`}
  alternateEn={`https://dumitrux.github.io/tag/${slug}/`}
  alternateEs={`https://dumitrux.github.io/es/tag/${slug}/`}
>
  <TagPage tag={tag} posts={posts} allTags={allTags} lang="es" />
</Layout>
