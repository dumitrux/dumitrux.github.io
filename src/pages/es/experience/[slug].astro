---
import Layout from '../../../layouts/Layout.astro';
import { workExperience } from '../../../data/experience';

export function getStaticPaths() {
  return workExperience.map((exp) => ({
    params: { slug: exp.slug },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const lang = 'es';
---

<Layout title={`${exp.name} | Dumitru`}>
  <section class="py-8 max-w-3xl mx-auto">
    <a href="/es/#experience" class="text-primary hover:underline text-sm mb-6 inline-flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Volver a Experiencia
    </a>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mt-4 mb-2">{exp.name}</h1>
    <p class="text-sm text-gray-500 dark:text-dark-muted mb-6">{exp.period}</p>
    <p class="text-gray-800 dark:text-dark-muted leading-relaxed mb-8">{exp.details[lang]}</p>
    <div class="flex flex-wrap gap-2">
      {exp.skills.map((skill) => (
        <span class="px-3 py-1 text-sm rounded-md bg-primary/10 text-primary border border-primary/20">
          {skill}
        </span>
      ))}
    </div>
  </section>
</Layout>
