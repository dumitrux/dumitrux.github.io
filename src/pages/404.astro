---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/ui';

const t = useTranslations('en');
---

<Layout title="404 | Dumitru" description="Page not found.">
  <section class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-7xl font-bold text-primary">404</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">{t('notFound.title')}</h1>
    <p class="mt-3 max-w-md text-gray-700 dark:text-dark-muted">{t('notFound.message')}</p>
    <a
      href="/"
      class="mt-8 inline-block rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary/90"
    >
      {t('notFound.home')}
    </a>
  </section>
</Layout>
