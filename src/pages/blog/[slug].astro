---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostArticle from '../../components/PostArticle.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => post.data.lang === 'en')
    .map((post) => ({
      params: { slug: post.data.permalink },
      props: { post },
    }));
}

const { post } = Astro.props;

const site = Astro.site?.origin ?? 'https://dumitrux.github.io';
const canonical = `${site}/blog/${post.data.permalink}/`;
const alternateEn = canonical;
const alternateEs = `${site}/es/blog/${post.data.permalink}/`;
---

<Layout
  title={`${post.data.title} | Dumitru`}
  description={post.data.description}
  image={post.data.thumbnail}
  canonical={canonical}
  alternateEn={alternateEn}
  alternateEs={alternateEs}
>
  <PostArticle post={post} lang="en" />
</Layout>
